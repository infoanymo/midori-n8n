      "id": "node_respond",
      "name": "即時200 OK返却",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [460, 180]
    },
    {
      "parameters": {
        "jsCode": "// Chatwork Webhookペイロードをパース\nconst body = $input.first().json.body;\nlet payload;\ntry {\n  payload = typeof body === 'string' ? JSON.parse(body) : body;\n} catch(e) {\n  return [{ json: { skip: true, reason: 'parse error' } }];\n}\n\nconst event = payload?.webhook_event || {};\nconst roomId   = String(event.room_id || '');\nconst senderId = String(event.from_account_id || '');\nconst rawBody  = String(event.body || '');\n\n// Toタグ・引用タグを除去してクリーンなテキストを取得\nconst cleanBody = rawBody\n  .replace(/\\[To:\\d+\\][^\\n]*/g, '')\n  .replace(/\\[reply[^\\]]*\\].*?\\[\\/reply\\]/gs, '')\n  .replace(/\\[info\\].*?\\[\\/info\\]/gs, '')\n  .trim();\n\nreturn [{ json: { roomId, senderId, rawBody, cleanBody, payload } }];"
      },
      "id": "node_parse",
      "name": "ペイロードパース＆テキスト整形",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 340]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond_self",
              "leftValue": "={{ $json.senderId }}",
              "rightValue": "11156703",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              }
            },
            {
              "id": "cond_empty",
              "leftValue": "={{ $json.cleanBody }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "node_filter_self",
      "name": "みどり自身の発言を除外",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [680, 340]
    },
    {
      "parameters": {
        "jsCode": "const body = $json.cleanBody || '';\nconst MIDORI_ID = '11156703';\n\n// トリガーワード判定\nconst triggerWords = ['タグ設置', 'タグをお願い', 'タグお願い', 'タグ入れて', '計測タグ', 'tag設置', 'TAG設置'];\nconst isTrigger = triggerWords.some(w => body.includes(w));\n\n// 承認・キャンセル判定\nconst isApprove = body.includes('承認') || body.toLowerCase().includes('ok');\nconst isCancel  = body.includes('キャンセル') || body.includes('やめ');\n\n// actionを決定\nlet action;\nif (isTrigger) {\n  action = 'start';\n} else if (isApprove) {\n  action = 'approve';\n} else if (isCancel) {\n  action = 'cancel';\n} else {\n  action = 'input';\n}\n\nreturn [{ json: { ...$json, action } }];"
      },
      "id": "node_route",
      "name": "アクション判定（start/input/approve/cancel）",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 340]
    },
    {
