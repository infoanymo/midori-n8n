          "values": [
            {
              "name": "action",
              "value": "={{ $json.action }}"
            },
            {
              "name": "roomId",
              "value": "={{ $json.roomId }}"
            },
            {
              "name": "body",
              "value": "={{ $json.cleanBody }}"
            }
          ]
        },
        "options": {}
      },
      "id": "node_call_gas",
